# =============================================================================
# fab-agent — environment template
#
# Copy to `.env` and edit. All variables are prefixed with FAB_ so they can
# safely coexist with other tools in your shell. The agent never reads the
# ambient environment for secrets without the FAB_ prefix.
# =============================================================================


# -----------------------------------------------------------------------------
# LLM provider
# -----------------------------------------------------------------------------
# Provider identifier. `litellm` accepts:
#   openai, anthropic, openrouter, ollama, azure, bedrock, vertexai, ...
# Bare names ("openai", "anthropic", "ollama") are mapped automatically.
# You can also pass a fully-qualified litellm model string in FAB_LLM_MODEL
# and leave FAB_LLM_PROVIDER blank.
FAB_LLM_PROVIDER=openai

# Model name. Examples:
#   gpt-4o
#   gpt-4o-mini
#   anthropic/claude-sonnet-4-20250514
#   anthropic/claude-3-5-sonnet-latest
#   openrouter/anthropic/claude-3.5-sonnet
#   ollama/llama3.1
FAB_LLM_MODEL=gpt-4o

# Provider API key. Not required for ollama.
# FAB_LLM_API_KEY=sk-...

# Optional base URL override (e.g. for OpenRouter, an OpenAI-compatible proxy,
# or a self-hosted ollama behind a tunnel).
# FAB_LLM_BASE_URL=https://openrouter.ai/api/v1


# -----------------------------------------------------------------------------
# WebSocket server
# -----------------------------------------------------------------------------
# Loopback by default. Do NOT expose this port to your network without adding
# TLS + a real auth layer (the v1 token is a shared secret, not auth).
FAB_AGENT_HOST=127.0.0.1

# Must match the port configured in the Foundry module settings.
FAB_AGENT_PORT=7777

# Shared secret. Must EXACTLY match the value entered in the FVTT-CC-Generator
# module settings inside Foundry. The Foundry client sends it via the
# `Sec-WebSocket-Protocol: fab.v1.token=<token>` header and the server rejects
# any connection whose token does not match.
FAB_AGENT_TOKEN=change-me-in-module-settings


# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
# Standard level name: DEBUG, INFO, WARNING, ERROR, CRITICAL.
FAB_LOG_LEVEL=INFO
